                  "text": "HEALTHY",
                  "color": "green",
                  "index": 1
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "min"
          ]
        },
        "textMode": "value",
        "justifyMode": "center"
      },
      "title": "Are We Good?",
      "description": "Minimum pg_up across all instances. HEALTHY = all nodes reachable. CRITICAL = at least one node down.",
      "type": "stat",
      "targets": [
        {
          "expr": "min(pg_up{instance=~\"$instance\"})",
          "legendFormat": "",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "green",
                "value": 0.3
              }
            ]
          },
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto"
      },
      "title": "Capacity Headroom",
      "description": "Connection capacity remaining. Shows (1 - worst connection ratio) across all instances. Red < 10%, Yellow < 30%, Green > 30%.",
      "type": "gauge",
      "targets": [
        {
          "expr": "1 - max(pg_connections_used_ratio{instance=~\"$instance\"})",
          "legendFormat": "free",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "title": "Worst Bottleneck",
      "description": "Longest running query across all instances. Green < 5s, Yellow < 30s, Orange < 5min, Red > 5min.",
      "type": "stat",
      "targets": [
        {
          "expr": "max(pg_longest_query_seconds{instance=~\"$instance\"})",
          "legendFormat": "longest query",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        },
        {
          "expr": "max(pg_lock_blocked_queries{instance=~\"$instance\"})",
          "legendFormat": "blocked queries",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "drawStyle": "line",
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "connection usage"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "regressions"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "slow queries"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Trend",
      "description": "Are things getting better or worse? Regressions (red), slow queries (orange), and connection usage (blue, right axis).",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(pg_stmt_regressions{instance=~\"$instance\"})",
          "legendFormat": "regressions",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        },
        {
          "expr": "sum(pg_slow_queries{instance=~\"$instance\"})",
          "legendFormat": "slow queries",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        },
        {
          "expr": "max(pg_connections_used_ratio{instance=~\"$instance\"})",
          "legendFormat": "connection usage",
          "datasource": {
            "type": "prometheus",
            "uid": ""
          }
        }
      ]
    }
