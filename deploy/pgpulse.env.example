# Required: PostgreSQL connection string
PG_DSN=postgres://pgpulse@localhost:5432/postgres?sslmode=disable

# Optional: metrics server port (default: 9187)
# METRICS_PORT=9187

# Optional: poll interval (default: 5s)
# POLL_INTERVAL=5s

# Optional: slow query threshold (default: 5s)
# SLOW_QUERY_THRESHOLD=5s

# Optional: regression detection threshold (default: 2.0x)
# REGRESSION_THRESHOLD=2.0

# Optional: number of top statements to track per dimension (default: 50)
# STMT_LIMIT=50

# Optional: Telegram alerting
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=-1001234567890

# Optional: Slack/generic webhook alerting
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Optional: alert cooldown period (default: 5m)
# ALERT_COOLDOWN=5m
